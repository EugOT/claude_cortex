{
  "name": "cortex",
  "description": "Native Zig local memory for Claude Code with MCP tools, Markdown wiki storage, and session checkpoints.",
  "version": "4.0.0-native",
  "author": {
    "name": "Clement Deust",
    "email": "admin@ai-architect.tools"
  },
  "homepage": "https://github.com/cdeust/Cortex",
  "repository": "https://github.com/cdeust/Cortex",
  "license": "MIT",
  "keywords": [
    "memory",
    "persistent",
    "mcp",
    "claude-code",
    "native",
    "zig"
  ],
  "userConfig": {
    "cortex_home": {
      "type": "string",
      "title": "Cortex home",
      "description": "Optional local data directory. Leave empty to use the Claude plugin data directory or the default home directory.",
      "default": ""
    },
    "database_url": {
      "type": "string",
      "title": "Database URL (deprecated)",
      "description": "Deprecated compatibility setting from the previous PostgreSQL runtime. Native Cortex ignores this value; use Cortex home for local file-backed storage.",
      "default": ""
    }
  },
  "mcpServers": {
    "cortex": {
      "command": "${CLAUDE_PLUGIN_ROOT}/zig-out/bin/cortex",
      "args": [
        "mcp"
      ],
      "env": {
        "CORTEX_HOME": "${user_config.cortex_home}",
        "CORTEX_DATABASE_URL": "${user_config.database_url}",
        "CORTEX_RUNTIME": "native-zig"
      }
    }
  },
  "postInstall": {
    "command": "cd ${CLAUDE_PLUGIN_ROOT} && zig build -Doptimize=ReleaseSafe",
    "message": "Building the native Cortex binary. Requires Zig 0.16 or newer on PATH."
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/zig-out/bin/cortex hook session-start",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/zig-out/bin/cortex hook user-prompt-submit",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/zig-out/bin/cortex hook post-tool-use",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/zig-out/bin/cortex hook session-end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
